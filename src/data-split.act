defproc split(chan?(int<8>) in; chan!(int<4>) out1;chan!(int<4>) out2)
{
    int<8> inside;
    int<4> res1, res2;
    chp{
     *[ in?inside;
        res1 := inside % 16;       /* lower 4 bits (LSB nibble) */
        res2 := (inside / 16) % 16; /* upper 4 bits (MSB nibble) */
        out1!res1;
        out2!res2
     ]
    }

}