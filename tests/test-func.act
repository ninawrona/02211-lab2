import "src/2-way-function.act";

defproc src1 (chan!(int<8>) X)
{
   chp {
      X!3; X!5; X!120; X!255
   }
}

defproc src2(chan!(int<8>) X)
{
   chp {
      X!7; X!9; X!120; X!1
   }
}

defproc sink(chan?(int<8>) X)
{
   int x;
   chp {
      // We know exactly what sequence to expect based on our sources
      X?x; log ("received ", x); assert(x = 10);
      X?x; log ("received ", x); assert(x = 14);
      X?x; log ("received ", x); assert(x = 240);
      X?x; log ("received ", x); assert(x = 0);

      log ("All assertions passed successfully!")
   }
}

defproc test()
{
  adder a;
  src1 s1(a.A);
  src2 s2(a.B);
  sink sx(a.out);
}
